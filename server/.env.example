# ─────────────────────────────────────────────────────────────
# Product Imagination Agents OS — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# Anthropic Claude (recommended — best quality)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI GPT-4o (fallback + Whisper voice)
OPENAI_API_KEY=sk-your-key-here

# Server port (default 3000)
PORT=3000

# Allowed origin for CORS — set to your live domain when hosting
# e.g. https://portal.productimagination.com
# Use * to allow all (only for local dev)
ALLOWED_ORIGIN=*
